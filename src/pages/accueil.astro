---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import iconBonjour from "../assets/icons/iconBonjour.svg?url"
import guillemetOuvrant from "../assets/icons/guillemetOuvrant.svg?url"
import guillemetFermant from "../assets/icons/guillemetFermant.svg?url"
import { getConseilDuJour } from "../composables/useConseilDuJour.js";
import { getRecettesDuJour } from "../composables/getRecettesDuJour.js";
import MobileLine from "../assets/icons/mobileLine.astro"
import Button from "../components/Button.astro";

const { locals,redirect } = Astro;

if(!locals.pb.authStore.isValid){
    return redirect("/")
}

const user = locals.pb.authStore.record;
const avatarUrl = user?.avatar
    ? locals.pb.files.getURL(user, user.avatar)
    : null;

const conseilDuJour = await getConseilDuJour(locals.pb, user?.objectif);
const recettesDuJour = await getRecettesDuJour(locals.pb);
---

<Layout showHeader titrePage="Accueil">
    <div class="bg-secondary flex flex-col lg:flex gap-10 lg:gap-0 lg:flex-row pt-30 pb-30 md:pt-70 px-5 sm:px-7 md:px-10 lg:px-30 z-30">
        <div class="flex flex-col gap-10">
            <h1 class="flex flex-col font-montserrat uppercase w-full">
                <span class="text-tertiary font-medium text-xl md:text-2xl lg:text-3xl">Bonjour</span>
                <span class="text-white font-bold text-3xl md:text-4xl lg:text-5xl flex w-full gap-2">
                    {user?.prenom} {user?.nom}
                    <img src={iconBonjour} alt="icon de bienvenue" class="w-8 md:w-12">
                </span>
            </h1>
            <div class="flex flex-col w-full txt-lg md:text-xl sm:w-6/7 xl:w-3/5 px-2 -space-y-2">
                <img src={guillemetOuvrant} alt="guillemet ouvrant" class="w-5">
                <p class="font-montserrat pl-6 pr-4 text-tertiary font-light italic uppercase">
                    Aider chaque visiteur à manger mieux selon SES objectifs et monétiser cet accompagnement.
                </p>
                <img src={guillemetFermant} alt="guillemet fermant" class="w-5 ml-auto">
            </div>
        </div>
        <div class="py-5 space-y-5 text-center flex flex-col bg-tertiary rounded-4xl w-fit mx-auto">
            <h2 class="uppercase font-modak text-primary text-3xl">Conseil du jour</h2>
            <div class="flex flex-col space-y-2">
            <p class="font-medium font-montserrat text-dark">Conseil adapté à votre objectif :</p>
            <p class="font-montserrat pl-6 pr-4 text-primary font-bold">
            {conseilDuJour}
            </p>
            </div>
        </div>
    </div>
    <div class="-mt-2 -mb-3 md:-mt-4 md:-mb-5 lg:-mt-6 lg:-mb-7 relative z-10">
        <MobileLine />
    </div>
    <div class="bg-tertiary z-20 flex flex-col items-center py-20 px-5 sm:px-7 md:px-10 lg:px-30 gap-10">
        <h2 class="font-modak text-primary text-4xl sm:text-5xl lg:text-6xl uppercase">Recettes du jour</h2>
        <div class="flex flex-col md:flex-row gap-6 w-full justify-center">
            {recettesDuJour.map((recette, i) => {
                const imageUrl = recette.image
                    ? locals.pb.files.getURL(recette, recette.image)
                    : null;
                const bg = i % 2 === 0 ? "secondary" : "primary";
                return (
                    <a href={`/recettes/${recette.id}`} class={`flex flex-col bg-${bg} rounded-3xl overflow-hidden w-full md:w-1/3 hover:scale-105 transition ease-in-out`}>
                        {imageUrl && <img src={imageUrl} alt={recette.titre} class="w-full h-40 object-cover" />}
                        <div class="p-4 flex flex-col gap-2">
                            <h3 class="font-modak text-tertiary text-2xl">{recette.titre}</h3>
                            <p class="font-montserrat text-tertiary/70 text-sm font-medium">{recette.description}</p>
                            <div class="flex justify-between font-montserrat font-bold text-xs mt-auto pt-2">
                                <span class={`bg-tertiary px-2 py-1 rounded-full text-${bg}`}>{recette.temps_preparation} min</span>
                                <span class={`bg-tertiary px-2 py-1 rounded-full text-${bg}`}>{recette.difficulte}</span>
                            </div>
                        </div>
                    </a>
                );
            })}
        </div>
        <Button bgClass="tertiary", colorClass="secondary", text="en voir plus", page="recettes", borderColor = "secondary", size = "md" />
    </div>
    <div class="-mt-2 -mb-3 md:-mt-4 md:-mb-5 lg:-mt-6 lg:-mb-7 relative z-10">
        <MobileLine lineColor="tertiary" />
    </div>
    <div class="bg-primary z-20 flex flex-col items-center py-20 px-5 sm:px-7 md:px-10 lg:px-30 gap-10">
        <h2 class="font-modak text-tertiary text-4xl sm:text-5xl lg:text-6xl uppercase">changer ton objectif</h2>
    </div>
</Layout>
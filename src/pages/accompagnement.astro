---
import Layout from "../layouts/Layout.astro";

const { locals, redirect } = Astro;
if (!locals.pb.authStore.isValid) return redirect("/");

const services = [
    {
        titre: "Diététicien-nutritionniste",
        description: "Consultez un professionnel agréé pour un bilan nutritionnel complet et un programme alimentaire sur-mesure adapté à vos objectifs.",
        tags: ["Consultation en ligne", "Remboursable"],
        lien: "https://www.livi.fr/",
        couleur: "bg-secondary",
        textColor: "text-tertiary",
        tagColor: "bg-tertiary/20 text-tertiary",
        btnColor: "bg-tertiary text-secondary",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" /></svg>`,
    },
    {
        titre: "Coach sportif & bien-être",
        description: "Un coach certifié vous accompagne avec un programme d'entraînement personnalisé pour atteindre vos objectifs physiques efficacement.",
        tags: ["Visio ou présentiel", "Essai gratuit"],
        lien: "https://www.coach-sportif.fr/",
        couleur: "bg-dark/15",
        textColor: "text-secondary",
        tagColor: "bg-secondary/10 text-secondary",
        btnColor: "bg-secondary text-tertiary",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
    },
    {
        titre: "Médecin du sport",
        description: "Bilan de santé complet, suivi médical sportif et conseils médicaux adaptés à votre pratique physique et votre alimentation.",
        tags: ["Remboursable SS", "Sur ordonnance"],
        lien: "https://www.medecindusport.fr/",
        couleur: "bg-primary",
        textColor: "text-white",
        tagColor: "bg-white/20 text-white",
        btnColor: "bg-white text-primary",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>`,
    },
    {
        titre: "Psychologue alimentaire",
        description: "Travaillez sur votre rapport à la nourriture, gérez les compulsions alimentaires et retrouvez une relation saine et sereine avec les aliments.",
        tags: ["Confidentiel", "En ligne"],
        lien: "https://www.mapsante.fr/",
        couleur: "bg-dark",
        textColor: "text-tertiary",
        tagColor: "bg-tertiary/10 text-tertiary",
        btnColor: "bg-tertiary text-dark",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 01-6.364 0M21 12a9 9 0 11-18 0 9 9 0 0118 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" /></svg>`,
    },
    {
        titre: "Naturopathe",
        description: "Approche naturelle et holistique pour rééquilibrer votre alimentation, renforcer votre vitalité et prévenir les carences nutritionnelles.",
        tags: ["Médecine douce", "Naturel"],
        lien: "https://www.omnes.net/",
        couleur: "bg-secondary/10",
        textColor: "text-secondary",
        tagColor: "bg-secondary/10 text-secondary",
        btnColor: "bg-secondary text-tertiary",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`,
    },
    {
        titre: "Coach en rééducation alimentaire",
        description: "Programme de rééducation progressive pour sortir des régimes yo-yo, stabiliser votre poids et adopter durablement de bonnes habitudes.",
        tags: ["Programme 12 semaines", "Suivi hebdo"],
        lien: "https://www.linecoaching.com/",
        couleur: "bg-primary/10",
        textColor: "text-primary",
        tagColor: "bg-primary/10 text-primary",
        btnColor: "bg-primary text-white",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" /></svg>`,
    },
];
---

<Layout showHeader titrePage="Accompagnement" headerColor="tertiary" description="Trouvez les professionnels de santé et du bien-être pour vous accompagner vers vos objectifs nutritionnels.">
    <section class="bg-secondary pt-32 md:pt-44 pb-20 px-5 sm:px-7 md:px-10 lg:px-20">
        <div class="max-w-3xl">
            <p class="font-montserrat text-tertiary/60 text-sm font-semibold uppercase tracking-widest mb-3">Services professionnels</p>
            <h1 class="font-modak text-tertiary text-5xl sm:text-6xl lg:text-7xl uppercase leading-none mb-6">
                Votre accompagnement
            </h1>
            <p class="font-montserrat text-white/70 text-base sm:text-lg leading-relaxed max-w-xl">
                NŪRA vous met en relation avec des professionnels de santé et du bien-être pour vous aider à atteindre vos objectifs nutritionnels et sportifs.
            </p>
        </div>
    </section>

    <section class="bg-tertiary/10 px-5 sm:px-7 md:px-10 lg:px-20 py-16 pb-32">
        <div class="max-w-6xl mx-auto flex flex-col gap-6">
            <h2 class="font-modak text-secondary text-3xl uppercase tracking-wide">Nos partenaires</h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                {services.map((s) => (
                    <div class={`${s.couleur} rounded-3xl p-6 flex flex-col gap-4`}>
                        <div class={`${s.textColor}`} set:html={s.icon} />

                        <div class="flex flex-col gap-2 flex-1">
                            <h3 class={`font-modak text-xl uppercase leading-tight ${s.textColor}`}>{s.titre}</h3>
                            <p class={`font-montserrat text-sm leading-relaxed ${s.textColor} opacity-80`}>{s.description}</p>
                        </div>

                        <div class="flex flex-wrap gap-2">
                            {s.tags.map(tag => (
                                <span class={`${s.tagColor} text-xs font-semibold px-3 py-1 rounded-full font-montserrat`}>{tag}</span>
                            ))}
                        </div>

                        <a
                            href={s.lien}
                            target="_blank"
                            rel="noopener noreferrer"
                            class={`${s.btnColor} font-montserrat font-bold text-sm px-5 py-3 rounded-full text-center hover:opacity-80 transition`}
                        >
                            Consulter →
                        </a>
                    </div>
                ))}
            </div>
        </div>
    </section>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import Loupe from "../assets/icons/iconLoupe.svg?url";

const { locals, redirect, request } = Astro;

if (!locals.pb.authStore.isValid) return redirect("/");

const user = locals.pb.authStore.record;
const objectif = user?.objectif as string | undefined;

const url = new URL(request.url);
const page = Math.max(1, parseInt(url.searchParams.get("page") || "1"));
const PER_PAGE = 12;

const [recettesObjectif, toutesRecettes] = await Promise.all([
    objectif
        ? locals.pb.collection("Recettes").getList(1, 6, {
              filter: `objectif ?~ "${objectif}"`,
              requestKey: null,
          })
        : Promise.resolve({ items: [] }),
    locals.pb.collection("Recettes").getList(page, PER_PAGE, { requestKey: null }),
]);

const totalPages = Math.ceil(toutesRecettes.totalItems / PER_PAGE);

const pbUrl = import.meta.env.POCKETBASE_URL;

function imageUrl(recette: any) {
    return recette.image
        ? locals.pb.files.getURL(recette, recette.image)
        : null;
}
---

<Layout showHeader titrePage="Recettes">
    <div data-pb-url={pbUrl} class="bg-tertiary text-center flex flex-col pt-30 md:pt-35 pb-50 gap-16 px-5 sm:px-7 md:px-10 lg:px-20">
        <div class="flex flex-col items-center gap-8">
            <h1 class="font-modak text-secondary text-4xl sm:text-5xl uppercase">Nos recettes</h1>

            <div class="relative flex items-center">
                <input
                    id="search-input"
                    type="text"
                    placeholder="Rechercher une recette..."
                    class="w-full bg-secondary rounded-full px-5 py-3 font-montserrat text-tertiary placeholder:text-tertiary/75 outline-none focus:ring-3 focus:ring-primary"
                >
                <img src={Loupe} alt="rechercher" class="absolute right-4 pointer-events-none"/>
            </div>

            <div id="search-results" class="hidden flex-col gap-8">
                <p class="font-montserrat font-bold text-secondary uppercase text-sm">Résultat de la recherches :</p>
                <div id="search-grid" class="flex flex-wrap justify-center gap-5"></div>
                <p id="search-empty" class="hidden font-montserrat text-dark/50 italic">Aucune recette trouvée.</p>
            </div>
        </div>

        {objectif && recettesObjectif.items.length > 0 && (
            <div class="flex flex-col gap-8">
                <h2 class="font-modak text-secondary text-3xl sm:text-4xl uppercase">Pour votre objectif</h2>
                <div class="flex flex-wrap justify-center gap-5">
                    {recettesObjectif.items.map((recette: any, i: number) => {
                        const bg = i % 2 === 0 ? "secondary" : "primary";
                        const img = imageUrl(recette);
                        return (
                            <a href={`/recettes/${recette.id}`} class={`flex flex-col bg-${bg} rounded-3xl overflow-hidden hover:scale-105 transition ease-in-out w-full sm:w-72`}>
                                {img && <img src={img} alt={recette.titre} class="w-full h-40 object-cover" loading="lazy" />}
                                <div class="p-4 flex flex-col gap-2">
                                    <h3 class="font-modak text-tertiary text-xl">{recette.titre}</h3>
                                    <p class="font-montserrat text-tertiary/70 text-sm line-clamp-2">{recette.description}</p>
                                    <div class="flex justify-between font-montserrat font-bold text-xs mt-auto pt-2">
                                        <span class={`bg-tertiary px-2 py-1 rounded-full text-${bg}`}>{recette.temps_preparation} min</span>
                                        <span class={`bg-tertiary px-2 py-1 rounded-full text-${bg} capitalize`}>{recette.difficulte}</span>
                                    </div>
                                </div>
                            </a>
                        );
                    })}
                </div>
            </div>
        )}

        <div class="flex flex-col gap-8">
            <h2 class="font-modak text-secondary text-3xl sm:text-4xl uppercase">Toutes les recettes</h2>
            <div class="flex flex-wrap justify-center gap-5">
                {toutesRecettes.items.map((recette: any, i: number) => {
                    const bg = i % 2 === 0 ? "secondary" : "primary";
                    const img = imageUrl(recette);
                    return (
                        <a href={`/recettes/${recette.id}`} class={`flex flex-col bg-${bg} rounded-3xl overflow-hidden hover:scale-105 transition ease-in-out w-full sm:w-72`}>
                            {img && <img src={img} alt={recette.titre} class="w-full h-40 object-cover" loading="lazy" />}
                            <div class="p-4 flex flex-col gap-2">
                                <h3 class="font-modak text-tertiary text-xl">{recette.titre}</h3>
                                <p class="font-montserrat text-tertiary/70 text-sm line-clamp-2">{recette.description}</p>
                                <div class="flex justify-between font-montserrat font-bold text-xs mt-auto pt-2">
                                    <span class={`bg-tertiary px-2 py-1 rounded-full text-${bg}`}>{recette.temps_preparation} min</span>
                                    <span class={`bg-tertiary px-2 py-1 rounded-full text-${bg} capitalize`}>{recette.difficulte}</span>
                                </div>
                            </div>
                        </a>
                    );
                })}
            </div>

            {totalPages > 1 && (
                <nav aria-label="Pagination" class="flex justify-center items-center gap-2 mt-4 flex-wrap">
                    {page > 1 && (
                        <a href={`?page=${page - 1}`} class="px-4 py-2 rounded-full font-montserrat font-bold text-sm bg-secondary text-tertiary hover:scale-105 transition">←</a>
                    )}
                    {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
                        <a
                            href={`?page=${p}`}
                            class={`px-4 py-2 rounded-full font-montserrat font-bold text-sm transition hover:scale-105
                                ${p === page ? "bg-primary text-tertiary" : "bg-secondary text-tertiary"}`}
                        >
                            {p}
                        </a>
                    ))}
                    {page < totalPages && (
                        <a href={`?page=${page + 1}`} class="px-4 py-2 rounded-full font-montserrat font-bold text-sm bg-secondary text-tertiary hover:scale-105 transition">→</a>
                    )}
                </nav>
            )}
        </div>
    </div>
</Layout>

<script>
    const input = document.getElementById("search-input") as HTMLInputElement;
    const resultsdiv = document.getElementById("search-results") as HTMLElement;
    const grid = document.getElementById("search-grid") as HTMLElement;
    const emptyMsg = document.getElementById("search-empty") as HTMLElement;
    const pbUrl = document.querySelector("[data-pb-url]")?.getAttribute("data-pb-url") ?? "";

    let debounceTimer: ReturnType<typeof setTimeout>;

    function cardHTML(recette: any): string {
        const img = recette.image
            ? `${pbUrl}/api/files/${recette.collectionId}/${recette.id}/${recette.image}`
            : "";
        return `
            <a href="/recettes/${recette.id}" class="flex flex-col bg-secondary rounded-3xl overflow-hidden hover:scale-105 transition ease-in-out w-full sm:w-72">
                ${img ? `<img src="${img}" alt="${recette.titre}" class="w-full h-40 object-cover" loading="lazy" />` : ""}
                <div class="p-4 flex flex-col gap-2">
                    <h3 class="font-modak text-tertiary text-xl">${recette.titre}</h3>
                    <p class="font-montserrat text-tertiary/70 text-sm line-clamp-2">${recette.description ?? ""}</p>
                    <div class="flex justify-between font-montserrat font-bold text-xs mt-auto pt-2">
                        <span class="bg-tertiary px-2 py-1 rounded-full text-secondary">${recette.temps_preparation ?? "?"} min</span>
                        <span class="bg-tertiary px-2 py-1 rounded-full text-secondary capitalize">${recette.difficulte ?? ""}</span>
                    </div>
                </div>
            </a>
        `;
    }

    async function search(query: string) {
        if (!query.trim()) {
            resultsdiv.classList.add("hidden");
            resultsdiv.classList.remove("flex");
            return;
        }

        resultsdiv.classList.remove("hidden");
        resultsdiv.classList.add("flex");

        const resTitre = await fetch(`${pbUrl}/api/collections/Recettes/records?` + new URLSearchParams({
            filter: `titre ~ "${query}"`,
            perPage: "20",
        }));

        const dataTitre = await resTitre.json();
        const items: any[] = dataTitre.items ?? [];

        if (items.length === 0) {
            grid.innerHTML = "";
            emptyMsg.classList.remove("hidden");
        } else {
            emptyMsg.classList.add("hidden");
            grid.innerHTML = items.map(cardHTML).join("");
        }
    }

    input.addEventListener("input", () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => search(input.value), 350);
    });
</script>

---
import Layout from "../../layouts/Layout.astro";

const { locals, redirect, params } = Astro;

if (!locals.pb.authStore.isValid) return redirect("/");

let recette: any;
try {
    recette = await locals.pb.collection("Recettes").getOne(params.id!, {
        expand: "Recette_aliments_via_recette.aliment,Etapes_via_recette",
        requestKey: null,
    });
} catch {
    return redirect("/recettes");
}

const imageUrl = recette.image
    ? locals.pb.files.getURL(recette, recette.image)
    : null;

const recetteAliments: any[] = recette.expand?.Recette_aliments_via_recette ?? [];
const etapes: any[] = (recette.expand?.Etapes_via_recette ?? []).sort((a: any, b: any) => a.numero - b.numero);

interface IngredientItem {
    nom: string;
    quantite: number;
    unite: string;
    calories: number;
    proteines: number;
    glucides: number;
    lipides: number;
}

const ingredientsFlat: IngredientItem[] = [];
const ingredientsByGroupe = recetteAliments.reduce((acc: Record<string, IngredientItem[]>, ra: any) => {
    const aliment = Array.isArray(ra.expand?.aliment) ? ra.expand.aliment[0] : ra.expand?.aliment;
    if (!aliment) return acc;
    const groupe = aliment.categorie ?? "Autres";
    if (!acc[groupe]) acc[groupe] = [];
    const isWeight = ra.unite === "g" || ra.unite === "ml";
    const factor = isWeight ? ra.quantite / 100 : 1;
    const item: IngredientItem = {
        nom: aliment.nom,
        quantite: ra.quantite,
        unite: ra.unite,
        calories: Math.round((aliment.calories ?? 0) * factor),
        proteines: Math.round((aliment.proteines ?? 0) * factor),
        glucides: Math.round((aliment.glucides ?? 0) * factor),
        lipides: Math.round((aliment.lipides ?? 0) * factor),
    };
    acc[groupe].push(item);
    ingredientsFlat.push(item);
    return acc;
}, {} as Record<string, IngredientItem[]>);

const basePortions = recette.nb_portions ?? 1;
const totauxBase = ingredientsFlat.reduce(
    (acc, i) => ({ calories: acc.calories + i.calories, proteines: acc.proteines + i.proteines, glucides: acc.glucides + i.glucides, lipides: acc.lipides + i.lipides }),
    { calories: 0, proteines: 0, glucides: 0, lipides: 0 }
);
const totauxPortion = {
    calories: Math.round(totauxBase.calories / basePortions),
    proteines: Math.round(totauxBase.proteines / basePortions),
    glucides: Math.round(totauxBase.glucides / basePortions),
    lipides: Math.round(totauxBase.lipides / basePortions),
};

const noteMoyenne: number = recette.note_moyenne ?? 0;

const noteUser = await locals.pb.collection("Notes").getFirstListItem(
    `recette = "${recette.id}" && user = "${locals.pb.authStore.record.id}"`,
    { requestKey: null }
).catch(() => null);
const userValeur: number = noteUser?.valeur ?? 0;

const commentaires = await locals.pb.collection("Commentaires").getFullList({
    filter: `recette = "${recette.id}"`,
    expand: "user",
    sort: "-created",
    requestKey: null,
});

const currentUserId: string = locals.pb.authStore.record.id;
const pbUrl = import.meta.env.POCKETBASE_URL;
---

<Layout showHeader titrePage="Recettes">
    <div class="min-h-screen bg-tertiary font-montserrat pt-28 md:pt-36 pb-24 px-5 sm:px-7 md:px-10 lg:px-20 flex flex-col gap-10">

        <div class="flex flex-col md:flex-row gap-6 md:gap-10 items-start">
            {imageUrl && (
                <div class="w-full md:w-2/5 flex-shrink-0">
                    <img
                        src={imageUrl}
                        alt={recette.titre}
                        class="w-full rounded-xl object-cover max-h-72 md:max-h-none md:h-72 lg:h-80"
                    />
                </div>
            )}

            <div class="flex flex-col gap-3 md:w-3/5">
                <h1
                    class="font-montserrat font-extrabold uppercase text-secondary"
                    style="font-size:28px"
                >
                    {recette.titre}
                </h1>

                <p class="font-montserrat font-normal text-dark text-sm leading-relaxed mt-2">
                    {recette.description}
                </p>

                <div class="flex flex-wrap items-center gap-3 mt-1">
                    {recette.temps_preparation && (
                        <span class="bg-secondary text-white font-montserrat font-bold rounded-full" style="font-size:12px; padding:4px 14px">
                            ⏱ {recette.temps_preparation} min
                        </span>
                    )}
                    {recette.nb_portions && (
                        <span class="bg-secondary text-white font-montserrat font-bold rounded-full" style="font-size:12px; padding:4px 14px">
                            🍽 {recette.nb_portions} portion{recette.nb_portions > 1 ? "s" : ""}
                        </span>
                    )}
                </div>

                <div
                    id="rating-root"
                    data-recette-id={recette.id}
                    data-user-valeur={userValeur}
                    class="flex flex-col gap-1 mt-1"
                >
                    <div class="flex items-center gap-2">
                        <div id="stars-display" class="flex gap-0.5">
                            {Array.from({ length: 5 }, (_, i) => (
                                <button
                                    class="star-btn cursor-pointer transition-transform hover:scale-110"
                                    data-value={i + 1}
                                    style="font-size:26px; background:none; border:none; padding:0; line-height:1"
                                >
                                    <span class={i < userValeur ? "text-secondary" : "text-dark/20"}>★</span>
                                </button>
                            ))}
                        </div>
                        <span id="note-label" class="font-montserrat text-dark/50 text-xs">
                            {noteMoyenne > 0 ? `${noteMoyenne}/5` : "Pas encore noté"}
                        </span>
                    </div>
                    <p class="font-montserrat text-dark/40 text-xs">
                        {userValeur > 0 ? "Votre note" : "Notez cette recette"}
                    </p>
                </div>
            </div>
        </div>

        <div
            id="calc-root"
            data-base-portions={basePortions}
            data-totaux={JSON.stringify(totauxBase)}
            class="bg-secondary rounded-2xl p-5 flex flex-col gap-5"
        >
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                <h2 class="font-montserrat font-extrabold text-tertiary uppercase tracking-wide">
                    Valeurs nutritionnelles
                </h2>
                <div class="flex items-center gap-3">
                    <span class="font-montserrat text-white/70 text-sm">Pour</span>
                    <button id="portions-minus" class="w-8 h-8 rounded-full bg-tertiary text-secondary font-extrabold text-lg flex items-center justify-center hover:opacity-80 transition cursor-pointer">−</button>
                    <span id="portions-display" class="font-montserrat font-extrabold text-tertiary text-xl w-6 text-center">{basePortions}</span>
                    <button id="portions-plus" class="w-8 h-8 rounded-full bg-tertiary text-secondary font-extrabold text-lg flex items-center justify-center hover:opacity-80 transition cursor-pointer">+</button>
                    <span class="font-montserrat text-white/70 text-sm">portion{basePortions > 1 ? "s" : ""}</span>
                </div>
            </div>

            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                {[
                    {label: "Calories", key:"calories", unit: "kcal", val: totauxPortion.calories},
                    {label: "Protéines", key:"proteines", unit: "g", val: totauxPortion.proteines},
                    {label: "Glucides", key:"glucides", unit: "g", val: totauxPortion.glucides},
                    {label: "Lipides", key:"lipides", unit: "g", val: totauxPortion.lipides},
                ].map(m => (
                    <div class="bg-dark/30 rounded-xl p-4 flex flex-col gap-1">
                        <span class="font-montserrat text-white/60 text-xs uppercase tracking-wider">{m.label}</span>
                        <div class="flex items-baseline gap-1">
                            <span id={`macro-${m.key}`} class="font-montserrat font-extrabold text-tertiary text-2xl">{m.val}</span>
                            <span class="font-montserrat text-white/60 text-xs">{m.unit}</span>
                        </div>
                    </div>
                ))}
            </div>
        </div>

        <div class="flex flex-col md:flex-row gap-0 md:gap-0 rounded-2xl overflow-hidden">

            <div class="bg-secondary md:w-[35%] p-5 flex flex-col gap-2">
                <h2 class="font-montserrat font-extrabold text-tertiary uppercase tracking-wide">
                    Ingrédients
                </h2>

                {Object.keys(ingredientsByGroupe).length === 0 ? (
                    <p class="font-montserrat text-white/50 text-sm italic mt-2">Aucun ingrédient renseigné.</p>
                ) : (
                    Object.entries(ingredientsByGroupe).map(([groupe, items]) => (
                        <div class="mt-4">
                            <p class="font-montserrat font-bold text-white uppercase text-xs tracking-wider mb-2">
                                {groupe}
                            </p>
                            <ul class="flex flex-col gap-0.5">
                                {(items as any[]).map((item: any) => (
                                    <li
                                        class="ingredient-item font-montserrat text-white"
                                        data-base={item.quantite}
                                        data-unite={item.unite}
                                        data-nom={item.nom}
                                        style="font-size:13px; line-height:1.8"
                                    >
                                        · <span class="ing-qty">{item.quantite}{item.unite === "g" || item.unite === "ml" ? item.unite : " " + item.unite}</span> de {item.nom}
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                )}
            </div>

            <div class="bg-tertiary md:w-[65%] p-5 flex flex-col gap-2 border border-secondary/20 md:border-l-0">
                <h2 class="font-montserrat font-extrabold text-secondary uppercase tracking-wide text-center">
                    Préparation
                </h2>

                {etapes.length === 0 ? (
                    <p class="font-montserrat text-dark/50 text-sm italic mt-2 text-center">Aucune étape renseignée.</p>
                ) : (
                    <ol class="flex flex-col gap-3 mt-3">
                        {etapes.map((e: any) => (
                            <li class="font-montserrat text-dark flex gap-3" style="font-size:14px; line-height:1.7">
                                <span class="font-extrabold text-secondary flex-shrink-0" style="min-width:1.5rem">
                                    {e.numero}.
                                </span>
                                <span>{e.description}</span>
                            </li>
                        ))}
                    </ol>
                )}
            </div>
        </div>
        <div
            id="comments-root"
            data-recette-id={recette.id}
            data-current-user={currentUserId}
            data-pb-url={pbUrl}
            class="flex flex-col gap-6"
        >
            <h2 class="font-montserrat font-extrabold text-secondary uppercase tracking-wide">
                Commentaires <span id="comments-count" class="text-secondary/50 font-bold text-base">({commentaires.length})</span>
            </h2>

            <form id="comment-form" class="flex flex-col gap-3">
                <textarea
                    id="comment-input"
                    rows="3"
                    placeholder="Laissez un commentaire..."
                    class="w-full bg-white/80 rounded-xl px-4 py-3 font-montserrat text-dark text-sm placeholder-dark/40 outline-none focus:ring-2 focus:ring-secondary resize-none"
                ></textarea>
                <div class="flex justify-end">
                    <button
                        type="submit"
                        class="bg-secondary text-tertiary font-montserrat font-extrabold rounded-full px-6 py-2 text-sm cursor-pointer hover:opacity-90 transition"
                        style="letter-spacing:0.5px"
                    >
                        PUBLIER
                    </button>
                </div>
            </form>

            <div id="comments-list" class="flex flex-col gap-4">
                {commentaires.map((c: any) => {
                    const u = c.expand?.user;
                    const avatar = u?.avatar ? `${pbUrl}/api/files/${u.collectionId}/${u.id}/${u.avatar}` : null;
                    const isOwn = c.user === currentUserId;
                    const date = new Date((c.created ?? "").replace(" ", "T")).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });
                    return (
                        <div class="comment-item bg-white/60 rounded-2xl p-4 flex gap-3" data-id={c.id}>
                            {avatar
                                ? <img src={avatar} alt="avatar" class="w-10 h-10 rounded-full object-cover flex-shrink-0" />
                                : <div class="w-10 h-10 rounded-full bg-secondary flex items-center justify-center flex-shrink-0 font-montserrat font-bold text-tertiary text-sm">{u?.prenom?.[0] ?? "?"}</div>
                            }
                            <div class="flex flex-col gap-1 flex-1 min-w-0">
                                <div class="flex items-center justify-between gap-2">
                                    <div class="flex items-center gap-2">
                                        <span class="font-montserrat font-bold text-dark text-sm">{u?.prenom} {u?.nom}</span>
                                        <span class="font-montserrat text-dark/40 text-xs">{date}</span>
                                    </div>
                                    {isOwn && (
                                        <button
                                            class="delete-btn font-montserrat text-xs text-dark/40 hover:text-red-500 transition cursor-pointer"
                                            data-id={c.id}
                                        >
                                            Supprimer
                                        </button>
                                    )}
                                </div>
                                <p class="font-montserrat text-dark text-sm leading-relaxed">{c.contenu}</p>
                            </div>
                        </div>
                    );
                })}
                {commentaires.length === 0 && (
                    <p id="no-comments" class="font-montserrat text-dark/40 italic text-sm text-center py-4">Aucun commentaire pour l'instant. Soyez le premier !</p>
                )}
            </div>
        </div>
    </div>
</Layout>

<script>
    const root = document.getElementById("calc-root")!;
    const basePortions = parseInt(root.dataset.basePortions ?? "1");
    const totauxBase = JSON.parse(root.dataset.totaux ?? "{}") as Record<string, number>;

    const display = document.getElementById("portions-display")!;
    const btnMinus = document.getElementById("portions-minus")!;
    const btnPlus = document.getElementById("portions-plus")!;

    let portions = basePortions;

    function update() {
        display.textContent = String(portions);
        const factor = portions / basePortions;

        (["calories", "proteines", "glucides", "lipides"] as const).forEach(key => {
            const el = document.getElementById(`macro-${key}`)!;
            el.textContent = String(Math.round((totauxBase[key] ?? 0) * factor / basePortions));
        });

        document.querySelectorAll<HTMLElement>(".ingredient-item").forEach(li => {
            const base = parseFloat(li.dataset.base ?? "0");
            const unite = li.dataset.unite ?? "";
            const val = base * factor;
            const formatted = Number.isInteger(val) ? val : val.toFixed(1);
            const suffix = unite === "g" || unite === "ml" ? unite : " " + unite;
            li.querySelector(".ing-qty")!.textContent = `${formatted}${suffix}`;
        });
    }

    btnMinus.addEventListener("click", () => { if (portions > 1) { portions--; update(); } });
    btnPlus.addEventListener("click", () => { portions++; update(); });
</script>

<script>
    const commRoot = document.getElementById("comments-root")!;
    const recetteId = commRoot.dataset.recetteId!;
    const currentUser = commRoot.dataset.currentUser!;
    const pbUrl = commRoot.dataset.pbUrl!;
    const form = document.getElementById("comment-form") as HTMLFormElement;
    const input = document.getElementById("comment-input") as HTMLTextAreaElement;
    const list = document.getElementById("comments-list")!;
    const countEl = document.getElementById("comments-count")!;

    let count = parseInt(countEl.textContent?.replace(/\D/g, "") ?? "0");

    function formatDate(iso: string) {
        return new Date(iso.replace(" ", "T")).toLocaleDateString("fr-FR", { day: "numeric", month: "long", year: "numeric" });
    }

    function buildCard(c: any): HTMLElement {
        const u = c.expand?.user;
        const avatar = u?.avatar ? `${pbUrl}/api/files/${u.collectionId}/${u.id}/${u.avatar}` : null;
        const isOwn  = c.user === currentUser;
        const div = document.createElement("div");
        div.className = "comment-item bg-white/60 rounded-2xl p-4 flex gap-3";
        div.dataset.id = c.id;
        div.innerHTML = `
            ${avatar
                ? `<img src="${avatar}" alt="avatar" class="w-10 h-10 rounded-full object-cover flex-shrink-0" />`
                : `<div class="w-10 h-10 rounded-full bg-secondary flex items-center justify-center flex-shrink-0 font-montserrat font-bold text-tertiary text-sm">${u?.prenom?.[0] ?? "?"}</div>`
            }
            <div class="flex flex-col gap-1 flex-1 min-w-0">
                <div class="flex items-center justify-between gap-2">
                    <div class="flex items-center gap-2">
                        <span class="font-montserrat font-bold text-dark text-sm">${u?.prenom ?? ""} ${u?.nom ?? ""}</span>
                        <span class="font-montserrat text-dark/40 text-xs">${formatDate(c.created)}</span>
                    </div>
                    ${isOwn ? `<button class="delete-btn font-montserrat text-xs text-dark/40 hover:text-red-500 transition cursor-pointer" data-id="${c.id}">Supprimer</button>` : ""}
                </div>
                <p class="font-montserrat text-dark text-sm leading-relaxed">${c.contenu}</p>
            </div>
        `;
        return div;
    }

    function updateCount(delta: number) {
        count += delta;
        countEl.textContent = `(${count})`;
    }

    list.addEventListener("click", async (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLElement>(".delete-btn");
        if (!btn) return;
        const id = btn.dataset.id!;
        btn.textContent = "...";
        const res = await fetch("/api/comment-delete", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ id }),
        });
        if (res.ok) {
            btn.closest(".comment-item")?.remove();
            updateCount(-1);
            if (count === 0) {
                list.innerHTML = `<p id="no-comments" class="font-montserrat text-dark/40 italic text-sm text-center py-4">Aucun commentaire pour l'instant. Soyez le premier !</p>`;
            }
        }
    });

    form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const contenu = input.value.trim();
        if (!contenu) return;

        const submitBtn = form.querySelector("button[type=submit]") as HTMLButtonElement;
        submitBtn.disabled = true;
        submitBtn.textContent = "...";

        const res = await fetch("/api/comment-add", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ recetteId, contenu }),
        });

        submitBtn.disabled = false;
        submitBtn.textContent = "PUBLIER";

        if (res.ok) {
            const c = await res.json();
            const noMsg = document.getElementById("no-comments");
            noMsg?.remove();
            list.prepend(buildCard(c));
            updateCount(1);
            input.value = "";
        }
    });
</script>

<script>
    const ratingRoot = document.getElementById("rating-root")!;
    const recetteId = ratingRoot.dataset.recetteId!;
    const starBtns = Array.from(ratingRoot.querySelectorAll<HTMLButtonElement>(".star-btn"));
    const noteLabel = document.getElementById("note-label")!;

    let userValeur = parseInt(ratingRoot.dataset.userValeur ?? "0");

    function renderStars(hovered: number, selected: number) {
        const active = hovered || selected;
        starBtns.forEach((btn, i) => {
            const star = btn.querySelector("span")!;
            star.className = i < active ? "text-secondary" : "text-dark/20";
        });
    }

    starBtns.forEach(btn => {
        btn.addEventListener("mouseenter", () => renderStars(parseInt(btn.dataset.value!), userValeur));
        btn.addEventListener("mouseleave", () => renderStars(0, userValeur));

        btn.addEventListener("click", async () => {
            const valeur = parseInt(btn.dataset.value!);
            starBtns.forEach(b => (b.disabled = true));

            const res = await fetch("/api/note-recette", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ recetteId, valeur }),
            });

            starBtns.forEach(b => (b.disabled = false));

            if (res.ok) {
                const { moyenne, total } = await res.json();
                userValeur = valeur;
                renderStars(0, userValeur);
                noteLabel.textContent = `${moyenne}/5 (${total} vote${total > 1 ? "s" : ""})`;
                ratingRoot.querySelector("p")!.textContent = "Votre note";
            }
        });
    });

    renderStars(0, userValeur);
</script>

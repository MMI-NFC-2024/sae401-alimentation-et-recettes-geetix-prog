---
import Layout from "../../layouts/Layout.astro";
import AdminNav from "../../components/AdminNav.astro";
import { createAdminPb } from "../../utils/pb";
import { loadAdminAuth } from "../../utils/adminAuth";

const { request, redirect } = Astro;

const adminPb = loadAdminAuth(request.headers.get("cookie"));
if (!adminPb.authStore.isValid) return redirect("/admin/login");

const pbAdmin = await createAdminPb();
const aliments = await pbAdmin.collection("Aliments").getFullList({
    sort: "nom",
    requestKey: null,
});

const pbUrl = import.meta.env.POCKETBASE_URL;
---

<Layout titrePage="Admin - Aliments">
    <div class="min-h-screen bg-tertiary/20 font-montserrat">
        <AdminNav currentPage="/admin/aliments" />

        <main class="px-6 py-10 max-w-6xl mx-auto flex flex-col gap-6" data-pb-url={pbUrl}>
            <div class="flex items-center justify-between">
                <h1 class="font-modak text-3xl text-secondary uppercase tracking-wide">
                    Aliments <span class="font-montserrat text-dark/40 text-lg font-normal normal-case">({aliments.length})</span>
                </h1>
            </div>

            <div class="bg-white rounded-2xl shadow-sm p-6">
                <h2 class="font-modak text-xl text-secondary uppercase tracking-wide mb-5">Nouvel aliment</h2>
                <form id="create-form" enctype="multipart/form-data" class="flex flex-col gap-4">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-semibold text-secondary/70 uppercase tracking-wide">Nom <span class="text-primary">*</span></label>
                            <input id="nom" name="nom" type="text" required placeholder="ex : Poulet"
                                class="border border-secondary/20 rounded-xl px-3 py-2 text-sm text-dark focus:outline-none focus:ring-2 focus:ring-secondary/30" />
                        </div>
                        <div class="flex flex-col gap-1">
                            <label class="text-xs font-semibold text-secondary/70 uppercase tracking-wide">Catégorie <span class="text-primary">*</span></label>
                            <select id="categorie" name="categorie" required
                                class="border border-secondary/20 rounded-xl px-3 py-2 text-sm text-dark focus:outline-none focus:ring-2 focus:ring-secondary/30">
                                <option value="">— Choisir —</option>
                                <option value="légume">Légume</option>
                                <option value="fruit">Fruit</option>
                                <option value="viande">Viande</option>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                        {[
                            { id: "calories", label: "Calories", unit: "kcal" },
                            { id: "proteines", label: "Protéines", unit: "g" },
                            { id: "glucides", label: "Glucides", unit: "g" },
                            { id: "lipides", label: "Lipides", unit: "g" },
                        ].map(f => (
                            <div class="flex flex-col gap-1">
                                <label class="text-xs font-semibold text-secondary/70 uppercase tracking-wide">{f.label} <span class="text-dark/30 normal-case font-normal">/ 100g</span> <span class="text-primary">*</span></label>
                                <div class="relative">
                                    <input id={f.id} name={f.id} type="number" min="0" step="0.1" placeholder="0" required
                                        class="w-full border border-secondary/20 rounded-xl px-3 py-2 pr-10 text-sm text-dark focus:outline-none focus:ring-2 focus:ring-secondary/30" />
                                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-dark/30">{f.unit}</span>
                                </div>
                            </div>
                        ))}
                    </div>

                    <div class="flex flex-col gap-1">
                        <label class="text-xs font-semibold text-secondary/70 uppercase tracking-wide">Image <span class="text-dark/30 normal-case font-normal">(optionnel)</span></label>
                        <input id="image" name="image" type="file" accept="image/*"
                            class="text-sm text-dark/60 file:mr-3 file:py-1.5 file:px-4 file:rounded-full file:border-0 file:bg-secondary/10 file:text-secondary file:font-semibold file:text-xs hover:file:bg-secondary/20 cursor-pointer" />
                    </div>

                    <div class="flex items-center justify-between pt-1">
                        <p id="form-error" class="text-xs text-primary hidden"></p>
                        <button type="submit"
                            class="ml-auto bg-secondary text-tertiary text-sm px-6 py-2.5 rounded-full hover:bg-secondary/80 transition font-semibold">
                            Ajouter l'aliment
                        </button>
                    </div>
                </form>
            </div>

            <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
                <table class="w-full text-sm">
                    <thead class="bg-secondary/10 border-b border-secondary/20">
                        <tr>
                            <th class="text-left px-6 py-4 text-secondary font-semibold">Aliment</th>
                            <th class="text-left px-6 py-4 text-secondary font-semibold hidden sm:table-cell">Catégorie</th>
                            <th class="text-right px-6 py-4 text-secondary font-semibold hidden md:table-cell">Calories</th>
                            <th class="text-right px-6 py-4 text-secondary font-semibold hidden lg:table-cell">Protéines</th>
                            <th class="text-right px-6 py-4 text-secondary font-semibold hidden lg:table-cell">Glucides</th>
                            <th class="text-right px-6 py-4 text-secondary font-semibold hidden lg:table-cell">Lipides</th>
                            <th class="px-6 py-4"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-secondary/10">
                        {aliments.map((a: any) => {
                            const img = a.image
                                ? `${pbUrl}/api/files/${a.collectionId}/${a.id}/${a.image}`
                                : null;
                            return (
                                <tr class="hover:bg-secondary/5 transition">
                                    <td class="px-6 py-4 flex items-center gap-3">
                                        {img
                                            ? <img src={img} alt={a.nom} class="w-10 h-10 rounded-xl object-cover shrink-0" />
                                            : <div class="w-10 h-10 rounded-xl bg-secondary/10 shrink-0"></div>
                                        }
                                        <span class="font-semibold text-dark">{a.nom}</span>
                                    </td>
                                    <td class="px-6 py-4 hidden sm:table-cell">
                                        <span class="capitalize text-secondary bg-secondary/10 px-3 py-1 rounded-full text-xs font-medium">{a.categorie ?? "—"}</span>
                                    </td>
                                    <td class="px-6 py-4 text-right text-dark/60 hidden md:table-cell font-medium">{a.calories ?? "—"} <span class="text-dark/30 font-normal">kcal</span></td>
                                    <td class="px-6 py-4 text-right text-dark/60 hidden lg:table-cell">{a.proteines ?? "—"} g</td>
                                    <td class="px-6 py-4 text-right text-dark/60 hidden lg:table-cell">{a.glucides ?? "—"} g</td>
                                    <td class="px-6 py-4 text-right text-dark/60 hidden lg:table-cell">{a.lipides ?? "—"} g</td>
                                    <td class="px-6 py-4 text-right">
                                        <button
                                            class="delete-btn text-primary hover:text-primary/70 text-xs font-semibold transition cursor-pointer"
                                            data-id={a.id}
                                            data-collection="Aliments"
                                            data-nom={a.nom}
                                        >
                                            Supprimer
                                        </button>
                                    </td>
                                </tr>
                            );
                        })}
                    </tbody>
                </table>
                {aliments.length === 0 && (
                    <p class="text-center text-dark/40 py-10">Aucun aliment</p>
                )}
            </div>
        </main>
    </div>
</Layout>

<script>
    const pbUrl = (document.querySelector("[data-pb-url]") as HTMLElement)?.dataset.pbUrl ?? "";

    const form = document.getElementById("create-form") as HTMLFormElement;
    const formError = document.getElementById("form-error")!;

    form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const btn = form.querySelector("button[type=submit]") as HTMLButtonElement;
        btn.textContent = "Ajout...";
        btn.disabled = true;
        formError.classList.add("hidden");

        const res = await fetch("/apis/admin-aliment-create", {
            method: "POST",
            body: new FormData(form),
        });

        if (res.ok) {
            const aliment = await res.json();
            const tbody = document.querySelector("tbody")!;
            const img = aliment.image
                ? `${pbUrl}/api/files/${aliment.collectionId}/${aliment.id}/${aliment.image}`
                : null;

            const tr = document.createElement("tr");
            tr.className = "hover:bg-secondary/5 transition";
            tr.dataset.id = aliment.id;
            tr.innerHTML = `
                <td class="px-6 py-4 flex items-center gap-3">
                    ${img
                        ? `<img src="${img}" alt="${aliment.nom}" class="w-10 h-10 rounded-xl object-cover shrink-0" />`
                        : `<div class="w-10 h-10 rounded-xl bg-secondary/10 shrink-0"></div>`
                    }
                    <span class="font-semibold text-dark">${aliment.nom}</span>
                </td>
                <td class="px-6 py-4 hidden sm:table-cell">
                    <span class="capitalize text-secondary bg-secondary/10 px-3 py-1 rounded-full text-xs font-medium">${aliment.categorie || "—"}</span>
                </td>
                <td class="px-6 py-4 text-right text-dark/60 hidden md:table-cell font-medium">${aliment.calories || "—"} <span class="text-dark/30 font-normal">kcal</span></td>
                <td class="px-6 py-4 text-right text-dark/60 hidden lg:table-cell">${aliment.proteines || "—"} g</td>
                <td class="px-6 py-4 text-right text-dark/60 hidden lg:table-cell">${aliment.glucides || "—"} g</td>
                <td class="px-6 py-4 text-right text-dark/60 hidden lg:table-cell">${aliment.lipides || "—"} g</td>
                <td class="px-6 py-4 text-right">
                    <button class="delete-btn text-primary hover:text-primary/70 text-xs font-semibold transition cursor-pointer"
                        data-id="${aliment.id}" data-collection="Aliments" data-nom="${aliment.nom}">
                        Supprimer
                    </button>
                </td>
            `;

            tr.querySelector<HTMLButtonElement>(".delete-btn")!.addEventListener("click", handleDelete);
            tbody.prepend(tr);
            form.reset();
        } else {
            const { error } = await res.json().catch(() => ({ error: "Erreur inconnue" }));
            formError.textContent = error;
            formError.classList.remove("hidden");
        }

        btn.textContent = "Ajouter l'aliment";
        btn.disabled = false;
    });

    function handleDelete(this: HTMLButtonElement) {
        const btn = this;
        const id = btn.dataset.id!;
        const nom = btn.dataset.nom ?? "cet élément";
        const collection = btn.dataset.collection!;
        if (!confirm(`Supprimer "${nom}" définitivement ?`)) return;
        btn.textContent = "...";
        btn.disabled = true;
        fetch("/apis/admin-delete", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ collection, id }),
        }).then(res => {
            if (res.ok) btn.closest("tr")?.remove();
            else { btn.textContent = "Erreur"; btn.disabled = false; }
        });
    }

    document.querySelectorAll<HTMLButtonElement>(".delete-btn").forEach(btn => {
        btn.addEventListener("click", function(this: HTMLButtonElement) { handleDelete.call(this); });
    });
</script>

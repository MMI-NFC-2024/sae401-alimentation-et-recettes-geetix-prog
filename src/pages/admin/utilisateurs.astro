---
import Layout from "../../layouts/Layout.astro";
import { createAdminPb } from "../../utils/pb";
import { loadAdminAuth } from "../../utils/adminAuth";

const { request, redirect } = Astro;

const adminPb = loadAdminAuth(request.headers.get("cookie"));
if (!adminPb.authStore.isValid) return redirect("/admin/login");

const pbAdmin = await createAdminPb();
const utilisateurs = await pbAdmin.collection("users").getFullList({
    sort: "-created",
    expand: "regime",
    requestKey: null,
});

const pbUrl = import.meta.env.POCKETBASE_URL;
---

<Layout titrePage="Admin - Utilisateurs">
    <div class="min-h-screen bg-tertiary/20 font-montserrat">
        <nav class="bg-secondary text-white px-6 py-4 flex items-center gap-6 text-sm font-bold">
            <span class="font-modak text-xl text-tertiary tracking-wide">NŪRA ADMIN</span>
            <a href="/admin" class="text-white/60 hover:text-tertiary transition">Dashboard</a>
            <a href="/admin/recettes" class="text-white/60 hover:text-tertiary transition">Recettes</a>
            <a href="/admin/aliments" class="text-white/60 hover:text-tertiary transition">Aliments</a>
            <a href="/admin/utilisateurs" class="text-tertiary">Utilisateurs</a>
            <a href="/admin/notifications" class="text-white/60 hover:text-tertiary transition">Notifications</a>
            <div class="ml-auto flex items-center gap-4">
                <a href="/accueil" class="text-white/60 hover:text-white transition text-sm">← Retour au site</a>
                <form method="POST" action="/apis/admin-logout">
                    <button type="submit" class="text-primary hover:text-primary/70 text-sm font-semibold transition cursor-pointer">Déconnexion</button>
                </form>
            </div>
        </nav>

        <main class="px-6 py-10 max-w-6xl mx-auto flex flex-col gap-6">
            <div class="flex items-center justify-between">
                <h1 class="font-modak text-3xl text-secondary uppercase tracking-wide">
                    Utilisateurs <span class="font-montserrat text-dark/40 text-lg font-normal normal-case">({utilisateurs.length})</span>
                </h1>
            </div>

            <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
                <table class="w-full text-sm">
                    <thead class="bg-secondary/10 border-b border-secondary/20">
                        <tr>
                            <th class="text-left px-6 py-4 text-secondary font-semibold">Utilisateur</th>
                            <th class="text-left px-6 py-4 text-secondary font-semibold hidden sm:table-cell">Email</th>
                            <th class="text-left px-6 py-4 text-secondary font-semibold hidden md:table-cell">Objectif</th>
                            <th class="text-left px-6 py-4 text-secondary font-semibold hidden lg:table-cell">Régime adopté</th>
                            <th class="text-left px-6 py-4 text-secondary font-semibold hidden lg:table-cell">Inscrit le</th>
                            <th class="px-6 py-4"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-secondary/10">
                        {utilisateurs.map((u: any) => {
                            const avatar = u.avatar
                                ? `${pbUrl}/api/files/${u.collectionId}/${u.id}/${u.avatar}`
                                : null;
                            const date = new Date((u.created ?? "").replace(" ", "T")).toLocaleDateString("fr-FR");
                            const regime = u.expand?.regime?.nom ?? "—";
                            return (
                                <tr class="hover:bg-secondary/5 transition">
                                    <td class="px-6 py-4 flex items-center gap-3">
                                        {avatar
                                            ? <img src={avatar} alt={u.prenom} class="w-10 h-10 rounded-full object-cover shrink-0" />
                                            : <div class="w-10 h-10 rounded-full bg-secondary/20 shrink-0 flex items-center justify-center text-secondary text-sm font-bold">{u.prenom?.[0]?.toUpperCase()}</div>
                                        }
                                        <div>
                                            <p class="font-semibold text-dark">{u.prenom} {u.nom}</p>
                                            <p class="text-xs text-dark/40 sm:hidden">{u.email}</p>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-dark/60 hidden sm:table-cell">{u.email}</td>
                                    <td class="px-6 py-4 hidden md:table-cell">
                                        <span class="capitalize text-secondary bg-secondary/10 px-3 py-1 rounded-full text-xs font-medium">{u.objectif ?? "—"}</span>
                                    </td>
                                    <td class="px-6 py-4 text-dark/60 hidden lg:table-cell text-xs">{regime}</td>
                                    <td class="px-6 py-4 text-dark/40 hidden lg:table-cell text-xs">{date}</td>
                                    <td class="px-6 py-4 text-right">
                                        <button
                                            class="delete-btn text-primary hover:text-primary/70 text-xs font-semibold transition cursor-pointer"
                                            data-id={u.id}
                                            data-nom={`${u.prenom} ${u.nom}`}
                                        >
                                            Supprimer
                                        </button>
                                    </td>
                                </tr>
                            );
                        })}
                    </tbody>
                </table>
                {utilisateurs.length === 0 && (
                    <p class="text-center text-dark/40 py-10">Aucun utilisateur</p>
                )}
            </div>
        </main>
    </div>
</Layout>

<script>
    document.querySelectorAll<HTMLButtonElement>(".delete-btn").forEach(btn => {
        btn.addEventListener("click", async () => {
            const id = btn.dataset.id!;
            const nom = btn.dataset.nom ?? "cet utilisateur";
            if (!confirm(`Supprimer le compte de "${nom}" définitivement ?`)) return;
            btn.textContent = "...";
            btn.disabled = true;
            const res = await fetch("/apis/admin-delete", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ collection: "users", id }),
            });
            if (res.ok) {
                btn.closest("tr")?.remove();
            } else {
                btn.textContent = "Erreur";
                btn.disabled = false;
            }
        });
    });
</script>

---
import Layout from "../../layouts/Layout.astro";
import AdminNav from "../../components/AdminNav.astro";
import { createAdminPb } from "../../utils/pb";
import { loadAdminAuth } from "../../utils/adminAuth";

const { request, redirect } = Astro;

const adminPb = loadAdminAuth(request.headers.get("cookie"));
if (!adminPb.authStore.isValid) return redirect("/admin/login");

const pbAdmin = await createAdminPb();

const [users, recettes, aliments, regimes, commentaires] = await Promise.all([
    pbAdmin.collection("users").getList(1, 1, { requestKey: null }),
    pbAdmin.collection("Recettes").getList(1, 1, { requestKey: null }),
    pbAdmin.collection("Aliments").getList(1, 1, { requestKey: null }),
    pbAdmin.collection("Regimes").getList(1, 1, { requestKey: null }),
    pbAdmin.collection("Commentaires").getList(1, 1, { requestKey: null }),
]);

const stats = [
    { label: "Utilisateurs", value: users.totalItems, href: "/admin/utilisateurs", color: "bg-secondary", text: "text-tertiary" },
    { label: "Recettes", value: recettes.totalItems, href: "/admin/recettes", color: "bg-primary", text: "text-white" },
    { label: "Aliments", value: aliments.totalItems, href: "/admin/aliments", color: "bg-tertiary", text: "text-secondary" },
    { label: "Régimes", value: regimes.totalItems, href: "#", color: "bg-dark", text: "text-tertiary" },
    { label: "Commentaires", value: commentaires.totalItems, href: "#", color: "bg-primary/20", text: "text-primary" },
];

const recentRecettes = await pbAdmin.collection("Recettes").getList(1, 5, {
    sort: "-created",
    requestKey: null,
});

const recentUsers = await pbAdmin.collection("users").getList(1, 5, {
    sort: "-created",
    requestKey: null,
});
---

<Layout titrePage="Admin">
    <div class="min-h-screen bg-tertiary/20 font-montserrat">
        <AdminNav currentPage="/admin" />

        <main class="px-6 py-10 max-w-6xl mx-auto flex flex-col gap-10">
            <h1 class="font-modak text-3xl text-secondary uppercase tracking-wide">Dashboard</h1>

            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
                {stats.map((s) => (
                    <a href={s.href} class={`${s.color} rounded-2xl p-5 flex flex-col gap-2 shadow-sm hover:opacity-90 transition`}>
                        <span class={`text-3xl font-bold font-modak ${s.text}`}>{s.value}</span>
                        <span class={`text-sm font-semibold ${s.text} opacity-80`}>{s.label}</span>
                    </a>
                ))}
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div class="bg-white rounded-2xl p-6 shadow-sm">
                    <h2 class="font-modak text-xl text-secondary uppercase tracking-wide mb-4">Dernières recettes</h2>
                    <div class="flex flex-col divide-y divide-secondary/10">
                        {recentRecettes.items.map((r: any) => (
                            <div class="py-3 flex justify-between items-center">
                                <div>
                                    <p class="font-semibold text-dark text-sm">{r.titre}</p>
                                    <p class="text-xs text-dark/40 capitalize">{r.difficulte}</p>
                                </div>
                                <a href={`/recettes/${r.id}`} class="text-xs text-primary hover:text-primary/70 font-semibold transition">Voir →</a>
                            </div>
                        ))}
                    </div>
                    <a href="/admin/recettes" class="text-xs text-secondary/60 hover:text-secondary font-semibold mt-4 inline-block transition">Voir tout →</a>
                </div>

                <div class="bg-white rounded-2xl p-6 shadow-sm">
                    <h2 class="font-modak text-xl text-secondary uppercase tracking-wide mb-4">Derniers utilisateurs</h2>
                    <div class="flex flex-col divide-y divide-secondary/10">
                        {recentUsers.items.map((u: any) => (
                            <div class="py-3 flex justify-between items-center">
                                <div>
                                    <p class="font-semibold text-dark text-sm">{u.prenom} {u.nom}</p>
                                    <p class="text-xs text-dark/40">{u.email}</p>
                                </div>
                            </div>
                        ))}
                    </div>
                    <a href="/admin/utilisateurs" class="text-xs text-secondary/60 hover:text-secondary font-semibold mt-4 inline-block transition">Voir tout →</a>
                </div>
            </div>
        </main>
    </div>
</Layout>

---
import Layout from "../layouts/Layout.astro";
import Loupe from "../assets/icons/iconLoupe.svg?url";

const { locals, redirect } = Astro;

if (!locals.pb.authStore.isValid) return redirect("/");

const user = locals.pb.authStore.record;
const userObjectif: string = user?.objectif ?? "";
const userRegimeId: string = user?.regime ?? "";

const regimes = await locals.pb.collection("Regimes").getFullList({
    expand: "aliments_phares",
    requestKey: null,
});

const objectifs = [
    { value: "perdre du poids",emoji: "🔥", label: "PERDRE DU POIDS" },
    { value: "manger sain",emoji: "🌱", label: "MANGER SAIN" },
    { value: "booster son energie",emoji: "⚡", label: "BOOSTER SON ÉNERGIE" },
    { value: "prendre de la masse",emoji: "💪", label: "PRENDRE DE LA MASSE" },
];
---

<Layout showHeader titrePage="Régimes" description="Découvrez nos programmes alimentaires personnalisés selon votre objectif : perte de poids, prise de masse, maintien ou énergie.">
<div
    id="regimes-root"
    data-user-objectif={userObjectif}
    data-user-regime={userRegimeId}
    class="min-h-screen bg-secondary flex flex-col lg:flex-row pt-30 md:pt-35 pb-50 gap-10 px-5 sm:px-7 md:px-10 lg:px-20"
>

    <div class="flex flex-col gap-6 lg:w-3/5 order-2 lg:order-1">

        <h1 id="col-title" class="font-modak text-tertiary text-4xl sm:text-5xl uppercase">Les régimes</h1>

        <div class="relative">
            <input
                id="search-input"
                type="text"
                placeholder="Rechercher un régime..."
                class="w-full bg-tertiary rounded-full px-6 py-3 font-montserrat text-dark placeholder-dark/50 outline-none focus:ring-2 focus:ring-primary pr-12"
            />
            <img src={Loupe} alt="rechercher" class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none" />
        </div>

        {regimes.length === 0 ? (
            <p id="empty-msg" class="font-montserrat text-tertiary/60 italic text-center mt-8">Aucun régime disponible pour le moment.</p>
        ) : (
            <div id="regimes-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                {regimes.map((r: any) => {
                    const aliments: any[] = r.expand?.aliments_phares ?? [];
                    return (
                        <div
                            class="regime-card rounded-2xl overflow-hidden flex flex-col w-full"
                            data-objectif={r.objectif}
                            data-nom={r.nom?.toLowerCase() ?? ""}
                            data-id={r.id}
                        >
                            <div class="bg-tertiary p-5">
                                <span class="inline-block bg-secondary text-white font-montserrat text-xs font-semibold px-3 py-1 rounded-full capitalize">
                                    {r.objectif}
                                </span>
                                <h3 class="font-montserrat font-bold text-dark mt-2.5" style="font-size:20px">{r.nom}</h3>
                                <p class="font-montserrat font-normal text-dark mt-2 text-sm leading-relaxed">{r.description}</p>
                            </div>

                            <div class="bg-dark w-ful px-5 py-4">
                                <div class="flex justify-around text-center gap-5">
                                    <div class="flex flex-col">
                                        <span class="font-montserrat font-bold text-tertiary" style="font-size:28px">{r.calories_jour ?? "—"}</span>
                                        <span class="font-montserrat text-white" style="font-size:13px">kcal / jour</span>
                                    </div>
                                    <div class="w-px bg-tertiary self-stretch" style="height:40px;align-self:center"></div>
                                    <div class="flex flex-col">
                                        <span class="font-montserrat font-bold text-tertiary" style="font-size:28px">{aliments.length}</span>
                                        <span class="font-montserrat text-white" style="font-size:13px">aliment{aliments.length > 1 ? "s" : ""} phare{aliments.length > 1 ? "s" : ""}</span>
                                    </div>
                                </div>
                                <div class="mt-4 h-px bg-tertiary"></div>
                            </div>

                            <div class="bg-dark px-5 py-4">
                                <p class="font-montserrat text-white/70" style="font-size:13px; margin-bottom:10px">Aliments phares</p>
                                <div class="flex flex-wrap gap-2">
                                    {aliments.map((a: any) => (
                                        <span class="bg-secondary text-white font-montserrat font-semibold text-xs px-3 py-1 rounded-full" style="padding:5px 12px">
                                            {a.nom}
                                        </span>
                                    ))}
                                    {aliments.length === 0 && (
                                        <span class="font-montserrat text-white/40 text-xs italic">Aucun aliment renseigné</span>
                                    )}
                                </div>
                                <div class="mt-4 h-px bg-tertiary"></div>
                            </div>

                            <div class="bg-dark px-5 py-4 flex justify-center">
                                <button
                                    class={`adopt-btn font-montserrat font-extrabold rounded-full transition ${r.id === userRegimeId ? "bg-tertiary text-secondary cursor-default" : "bg-secondary text-tertiary hover:opacity-90 cursor-pointer"}`}
                                    data-id={r.id}
                                    style="font-size:13px; padding:10px 2rem; letter-spacing:1px"
                                    disabled={r.id === userRegimeId}
                                >
                                    {r.id === userRegimeId ? "RÉGIME ADOPTÉ" : "ADOPTER CE RÉGIME"}
                                </button>
                            </div>
                        </div>
                    );
                })}
            </div>
        )}

        <p id="no-results" class="hidden font-montserrat text-tertiary/60 italic text-center mt-4">Aucun régime trouvé.</p>

    </div>

    <div class="flex flex-col gap-6 lg:w-2/5 order-1 lg:order-2 lg:sticky lg:top-36 lg:self-start">

        <div class="flex flex-col gap-2">
            <h2 class="font-modak text-tertiary text-4xl sm:text-5xl uppercase">Régimes par objectif</h2>
            <p class="font-montserrat text-tertiary/70 text-sm">Trouve le régime adapté à ton objectif</p>
        </div>

        <div class="flex flex-col gap-3">
            <button
                class="objectif-btn font-modak uppercase text-base bg-tertiary text-secondary px-6 py-3 rounded-full text-left hover:opacity-90 transition"
                data-objectif=""
            >
                TOUS LES RÉGIMES
            </button>
            {objectifs.map((o) => (
                <button
                    class="objectif-btn font-modak uppercase text-base bg-tertiary text-secondary px-6 py-3 rounded-full text-left hover:opacity-90 transition"
                    data-objectif={o.value}
                >
                    {o.emoji} {o.label} {o.emoji}
                </button>
            ))}
        </div>

    </div>
</div>
</Layout>

<script>
    const root= document.getElementById("regimes-root")!;
    const userObjectif= root.dataset.userObjectif ?? "";
    const searchInput = document.getElementById("search-input") as HTMLInputElement;
    const colTitle= document.getElementById("col-title")!;
    const noResults= document.getElementById("no-results")!;
    const allCards= Array.from(document.querySelectorAll<HTMLElement>(".regime-card"));
    const allBtns= Array.from(document.querySelectorAll<HTMLButtonElement>(".objectif-btn"));

    let activeObjectif = userObjectif;
    let searchQuery= "";

    const objectifLabels: Record<string, string> = {
        "perdre du poids":"RÉGIMES POUR PERDRE DU POIDS",
        "manger sain":"RÉGIMES POUR MANGER SAIN",
        "booster son energie":"RÉGIMES POUR BOOSTER SON ÉNERGIE",
        "prendre de la masse":"RÉGIMES POUR PRENDRE DE LA MASSE",
    };

    function applyFilters() {
        let visible = 0;
        allCards.forEach(card => {
            const matchObj = !activeObjectif || card.dataset.objectif === activeObjectif;
            const matchSearch = !searchQuery || (card.dataset.nom ?? "").includes(searchQuery.toLowerCase());
            const show = matchObj && matchSearch;
            card.classList.toggle("hidden", !show);
            if (show) visible++;
        });
        noResults.classList.toggle("hidden", visible > 0);
        colTitle.textContent = activeObjectif
            ? (objectifLabels[activeObjectif] ?? "LES RÉGIMES")
            : "LES RÉGIMES";
    }

    function setActiveBtn(value: string) {
        allBtns.forEach(btn => {
            const isActive = btn.dataset.objectif === value;
            btn.classList.toggle("bg-tertiary",!isActive);
            btn.classList.toggle("text-secondary",!isActive);
            btn.classList.toggle("bg-primary",isActive);
            btn.classList.toggle("text-tertiary",isActive);
        });
    }

    allBtns.forEach(btn => {
        btn.addEventListener("click", () => {
            activeObjectif = btn.dataset.objectif ?? "";
            setActiveBtn(activeObjectif);
            applyFilters();
        });
    });

    let debounce: any;
    searchInput.addEventListener("input", () => {
        clearTimeout(debounce);
        debounce = setTimeout(() => {
            searchQuery = searchInput.value.trim();
            applyFilters();
        }, 250);
    });

    setActiveBtn(activeObjectif);
    applyFilters();

    let currentRegimeId = root.dataset.userRegime ?? "";

    function updateAdoptBtns() {
        document.querySelectorAll<HTMLButtonElement>(".adopt-btn").forEach(btn => {
            const isAdopted = btn.dataset.id === currentRegimeId;
            btn.textContent = isAdopted ? "RÉGIME ADOPTÉ" : "ADOPTER CE RÉGIME";
            btn.disabled = isAdopted;
            btn.classList.toggle("bg-tertiary", isAdopted);
            btn.classList.toggle("text-secondary", isAdopted);
            btn.classList.toggle("cursor-default", isAdopted);
            btn.classList.toggle("bg-secondary", !isAdopted);
            btn.classList.toggle("text-tertiary", !isAdopted);
            btn.classList.toggle("hover:opacity-90", !isAdopted);
            btn.classList.toggle("cursor-pointer", !isAdopted);
        });
    }

    document.querySelectorAll<HTMLButtonElement>(".adopt-btn").forEach(btn => {
        btn.addEventListener("click", async () => {
            const regimeId = btn.dataset.id!;
            btn.textContent = "...";
            btn.disabled = true;

            const res = await fetch("/apis/adopt-regime", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ regimeId }),
            });

            if (res.ok) {
                currentRegimeId = regimeId;
                updateAdoptBtns();
            } else {
                btn.textContent = "ADOPTER CE RÉGIME";
                btn.disabled = false;
            }
        });
    });
</script>

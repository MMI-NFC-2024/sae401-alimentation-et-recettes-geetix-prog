---
interface Props {
    bgClass: string;
    colorClass: string;
    text: string;
    page: string;
    borderColor?: string;
    size?: "sm" | "md" | "lg";
}

const { bgClass, colorClass, text, page, borderColor = "black", size = "md" } = Astro.props;

const scales = {
    sm: 1,
    md: 1.25,
    lg: 1.75,
};
---

<a
    href={page.startsWith("/") ? page : `/${page}`}
    style={`--btn-border: ${borderColor}; transform: scale(${scales[size]}); transform-origin: center;`}
    class={`inline-block ${bgClass} ${colorClass} uppercase px-4 sm:px-6 md:px-8 lg:px-10 py-1.5 sm:py-2 md:py-2.5 lg:py-3 rounded-full font-modak text-sm sm:text-base md:text-lg shadow-[0_0_0_2px_var(--btn-border),2px_2px_0px_1px_var(--btn-border)] sm:shadow-[0_0_0_2px_var(--btn-border),3px_3px_0px_1px_var(--btn-border)] md:shadow-[0_0_0_3px_var(--btn-border),4px_4px_0px_2px_var(--btn-border)] hover:scale-105 active:scale-95 transition-transform duration-150 ease-in text-center`}
>
    {text}
</a>

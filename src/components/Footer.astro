---
import Logo from "../assets/logo.svg?url";
import FooterLine from "../assets/lineFooter.webp?url"
---

<footer class="hidden md:block bg-primary pb-15">
    <img src={FooterLine} alt="" class="w-full -mt-15" />
    <div class="flex items-center pb-10 pt-5 justify-around">
        <a href="/accueil" class="flex justify-center align-center hover:scale-110 transition ease-in-out hover:-rotate-5">
            <img src={Logo} class="w-1/2" alt="Logo nura">
        </a>
        <nav class="flex flex-col space-y-5">
            <h4 class="font-montserrat uppercase font-bold text-tertiary text-2xl">Navigation</h4>
            <ul class="underline text-tertiary font-montserrat space-y-2">
                <li><a href="/aliments" class="hover:translate-x-1 inline-block transition ease-in-out">Aliments</a></li>
                <li><a href="/recettes" class="hover:translate-x-1 inline-block transition ease-in-out">Recettes</a></li>
                <li><a href="/regimes" class="hover:translate-x-1 inline-block transition ease-in-out">Régimes</a></li>
            </ul>
        </nav>
        <nav class="flex flex-col space-y-5">
            <h4 class="font-montserrat uppercase font-bold text-tertiary text-2xl">Mentions Légales</h4>
            <ul class="underline text-tertiary font-montserrat space-y-2">
                <li><a href="/mentions" class="hover:translate-x-1 inline-block transition ease-in-out">Mentions légales</a></li>
                <li><a href="/confidentialite" class="hover:translate-x-1 inline-block transition ease-in-out">Politique de confidentialité</a></li>
            </ul>
        </nav>
    </div>
</footer>